.button {
  display: inline-block;
  padding: 10px 20px;
  background: linear-gradient(90deg, #0278fe 0%, #003a7b 99.98%);
  color: white;
  text-decoration: none;
  border-radius: 5px;
  font-size: 16px;
  box-shadow: 10px 10px 25px 0px #00000080;
  width: 356.08px;
  height: 48px;
  margin-top: 48px;
  grid-area: button;
}

.button:hover {
  background-color: #003a7b;
  box-shadow: 5px 5px 10px 0px #00000040;
}
